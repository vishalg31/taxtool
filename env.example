# ─────────────────────────────────────────────
# India Tax Calculator — Environment Variables
# FY 2025-26
#
# Copy this file to .env.local for local dev.
# Add these keys in Vercel Dashboard → Settings → Environment Variables.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────

# Your production domain (used for CORS in API route)
# No trailing slash
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# App metadata (used in <head> and OG tags)
NEXT_PUBLIC_APP_NAME="India Tax Calculator"
NEXT_PUBLIC_APP_DESCRIPTION="Compare old vs new tax regime for FY 2025-26"

# ── Optional: Analytics ──────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxx

# ── Optional: Rate limiting (Upstash) ───────
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxx

# ── Optional: Error monitoring ───────────────
# SENTRY_DSN=https://xxxx@sentry.io/xxxx
